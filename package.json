{
  "name": "@joshuaavalon/eslint-config-react",
  "version": "11.1.2",
  "description": "Shareable ESLint React config.",
  "type": "module",
  "module": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src",
    "prebuild": "rimraf dist",
    "build": "tsc"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "files": [
    "dist"
  ],
  "author": "Joshua Avalon",
  "license": "Apache-2.0",
  "homepage": "https://github.com/joshuaavalon/eslint-config-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshuaavalon/eslint-config-react.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/joshuaavalon/eslint-config-react/issues"
  },
  "dependencies": {
    "@joshuaavalon/eslint-config-typescript": "^11.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-dom": "^5.8.7",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-x": "^5.8.7"
  },
  "devDependencies": {
    "@eslint/core": "^1.2.1",
    "@joshuaavalon/eslint-config-javascript": "^11.1.0",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "eslint": ">=10.4.1"
  }
}
